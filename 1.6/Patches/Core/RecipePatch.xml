				<requirements>
					<li>ChemicalSynthesis</li>
					<li>LLRoM_MagicRefinement</li>
				</requirements>
				<unqualifiedPenalty>
					<statModifiers>
						<li>
							<stat>GeneralLaborSpeed</stat>
							<applyGlobally>True</applyGlobally>
							<modifier>0.5</modifier>
						</li>
					</statModifiers>
				</unqualifiedPenalty>
				<hardRequirement>False</hardRequirement>
			</li>
		</value>
	</Operation>
	
