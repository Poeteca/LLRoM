<Patch>
	<Operation Class="PatchOperationReplace">
		<xpath>//ThingDef[@Name="TM_BaseWand"]/recipeMaker/unfinishedThingDef</xpath>
		<value>
			<unfinishedThingDef>UnfinishedMagicWeapon</unfinishedThingDef>
		</value>
	</Operation>
	
